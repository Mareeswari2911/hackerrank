class Result {
    public static int divisibleSumPairs(int n, int k, List<Integer> ar) {
    int count=0;
    for(int i=0;i<ar.size();i++)
    {
        int sum=0;
        int ele=ar.get(i);
        for(int j=i+1;j<ar.size();j++)
        {
            sum=ele+ar.get(j);
            if(sum%k==0)
            {
                count++;
            }
        }
    }
    return count;
    }

}
