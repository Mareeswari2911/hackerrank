import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        String S = in.next();
        int start = in.nextInt();
        int end = in.nextInt();
        String S1="";
        for(int i=start;i<end;i++)
        {
            char c=S.charAt(i);
            S1=S1+c;
        }
        System.out.println(S1);
    }
}
